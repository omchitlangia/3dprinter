// 3D-printing booking app — AI Center of Excellence, Shiv Nadar University
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

enum Role {
  user
  admin
}

enum PrinterStatus {
  available
  maintenance
  offline
}

enum BookingStatus {
  confirmed
  printing
  ready_for_pickup
  completed
  cancelled
  rejected
}

// ─────────────────────── Auth.js (NextAuth) ───────────────────────
// Standard Prisma adapter models, extended with our app `role`.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(user)
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  bookings     Booking[]
  auditEntries AuditLog[] @relation("AuditActor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Used by the email magic-link provider.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────── Domain ─────────────────────────────

model Printer {
  id        String        @id @default(cuid())
  name      String        @unique
  model     String?
  status    PrinterStatus @default(available)
  location  String?

  // Material/color compatibility used to filter printers at scheduling time.
  materials String[] @default([])
  colors    String[] @default([])

  // Daily operating window, minutes from midnight (local). Bookings must fall
  // inside [openMinute, closeMinute). e.g. 9:00–21:00 => 540 / 1260.
  openMinute  Int @default(540)
  closeMinute Int @default(1260)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings           Booking[]
  maintenanceWindows MaintenanceWindow[]
}

// Blocks a time range on a printer; overlapping bookings are rejected.
model MaintenanceWindow {
  id        String   @id @default(cuid())
  printerId String
  start     DateTime
  end       DateTime
  reason    String?
  createdAt DateTime @default(now())

  printer Printer @relation(fields: [printerId], references: [id], onDelete: Cascade)

  @@index([printerId, start, end])
}

model Booking {
  id                String        @id @default(cuid())
  userId            String
  printerId         String
  status            BookingStatus @default(confirmed)

  start             DateTime
  // Estimated print duration in minutes; end is derived as start + duration.
  estimatedDuration Int
  endsAt            DateTime

  // Print parameters.
  material String
  color    String
  notes    String?

  // Reference to the uploaded model in object storage (key + display name).
  // The file itself never lives in the DB or on the app server.
  fileKey  String
  fileName String
  fileSize Int

  // Reminder bookkeeping so the cron endpoint is idempotent.
  reminder24Sent Boolean @default(false)
  reminder1Sent  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  printer Printer @relation(fields: [printerId], references: [id], onDelete: Restrict)

  auditEntries AuditLog[]

  @@index([printerId, start, endsAt])
  @@index([userId])
  @@index([status])
}

// Audit trail for admin overrides (status changes, cancellations, etc).
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  bookingId  String?
  action     String // e.g. "status_change", "cancel", "printer_update"
  detail     String? // human-readable summary / before→after
  createdAt  DateTime @default(now())

  actor   User     @relation("AuditActor", fields: [actorId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([actorId])
}
