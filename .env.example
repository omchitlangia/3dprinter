# ──────────────────────────────────────────────────────────────────────────
# Core
# ──────────────────────────────────────────────────────────────────────────
# Public base URL of the app (used by Auth.js callbacks + email links)
NEXTAUTH_URL="http://localhost:3000"
# Random 32+ byte secret: `openssl rand -base64 32`
AUTH_SECRET="changeme-generate-with-openssl-rand-base64-32"

# ──────────────────────────────────────────────────────────────────────────
# Database (Prisma + Postgres)
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/coe3d?schema=public"

# ──────────────────────────────────────────────────────────────────────────
# Auth — Google OAuth
# ──────────────────────────────────────────────────────────────────────────
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# Comma-separated list of allowed email domains. Sign-ins from any other
# domain are rejected. e.g. "snu.edu.in,snuchennai.edu.in"
ALLOWED_EMAIL_DOMAINS="snu.edu.in"

# Comma-separated list of admin emails. These users are granted the admin
# role on sign-in (and seeded if missing).
ADMIN_EMAILS="admin@snu.edu.in"

# ──────────────────────────────────────────────────────────────────────────
# Email (Resend + React Email)
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Verified sender, e.g. "COE 3D Print <noreply@coe.snu.edu.in>"
EMAIL_FROM="COE 3D Print <noreply@example.com>"

# ──────────────────────────────────────────────────────────────────────────
# Object storage (S3-compatible: AWS S3, Cloudflare R2, MinIO, etc.)
# Files are uploaded directly from the browser via presigned URLs — never
# through the app server or DB.
# ──────────────────────────────────────────────────────────────────────────
S3_REGION="auto"
S3_BUCKET="coe-3d-uploads"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
# Required for R2/MinIO; omit/leave blank for plain AWS S3.
S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
# Set true for MinIO / path-style addressing.
S3_FORCE_PATH_STYLE="false"

# Max upload size in bytes (default 100 MB).
MAX_UPLOAD_BYTES="104857600"

# ──────────────────────────────────────────────────────────────────────────
# Rate limiting (Upstash Redis). If unset, an in-memory limiter is used
# (fine for dev / single instance; NOT safe across serverless instances).
# ──────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ──────────────────────────────────────────────────────────────────────────
# Cron / reminders
# Shared secret the cron caller must present (Bearer token) to hit the
# reminder endpoint. Generate with `openssl rand -hex 32`.
# ──────────────────────────────────────────────────────────────────────────
CRON_SECRET="changeme-generate-with-openssl-rand-hex-32"
