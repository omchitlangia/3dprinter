// 3D-printing print-application app — AI Center of Excellence, Shiv Nadar University
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

enum Role {
  user
  admin
}

// Supported filament types for a print application.
enum FilamentType {
  PLA
  ABS
  PETG
  TPU
}

// Lifecycle of an application. Every submission starts PENDING; an admin moves
// it to APPROVED (with a confirmed day) or REJECTED. There is no auto-confirm.
enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────── Auth.js (NextAuth) ───────────────────────
// Standard Prisma adapter models, extended with our app `role`.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(user)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]

  applications Application[] @relation("Applicant")
  decisions    Application[] @relation("Decider")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Used by the email magic-link provider.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────── Domain ─────────────────────────────

// A print application is a manual review request. The applicant proposes three
// distinct future days (a preferred day + two alternates); an admin approves it
// by confirming ONE of those three days, or rejects it (with an optional note).
// There is NO automatic scheduling — multiple applications may request the same
// day, and nothing is blocked by overlap.
model Application {
  id     String            @id @default(cuid())
  userId String
  status ApplicationStatus @default(PENDING)

  filament       FilamentType
  // Estimated print time in hours (positive). Float so "1.5" etc. is allowed.
  estimatedHours Float

  // Reference to the uploaded model in object storage (key + display name).
  // The file itself never lives in the DB or on the app server.
  fileKey  String
  fileName String
  fileSize Int

  // Three distinct future days the applicant is requesting.
  preferredDate DateTime
  altDate1      DateTime
  altDate2      DateTime

  // Set when an admin approves: which of the three days was confirmed.
  confirmedDate DateTime?

  // Decision metadata (set on approve OR reject).
  decisionNote String?
  decidedById  String?
  decidedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicant User  @relation("Applicant", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User? @relation("Decider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}
